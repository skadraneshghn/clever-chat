# ═══════════════════════════════════════════════════════════════════════════
# CleverChat — Root .gitignore
# ═══════════════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl

# ── Virtual Environments ─────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Node.js ──────────────────────────────────────────────────────────────
node_modules/
.next/
out/
.turbo/

# ── Environment Files ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
backend/.env

# ── IDE ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Uploads & Generated ─────────────────────────────────────────────────
uploads/
*.log
*.pid

# ── Testing ──────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ── Misc ─────────────────────────────────────────────────────────────────
*.db
*.sqlite3
.gemini/
