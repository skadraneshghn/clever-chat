# ═══════════════════════════════════════════════════════════════════════════
# CleverChat Backend — Environment Variables
# Copy to .env for local development
# On Clever Cloud, set these as environment variables in the dashboard
# ═══════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────
APP_NAME=CleverChat
ENVIRONMENT=production
DEBUG=false
PORT=8080

# ── Database (auto-injected by Clever Cloud PostgreSQL addon) ────────────
# POSTGRESQL_ADDON_URI=   (injected by CC)
# POSTGRESQL_ADDON_HOST=  (injected by CC)
# POSTGRESQL_ADDON_PORT=  (injected by CC)
# POSTGRESQL_ADDON_DB=    (injected by CC)
# POSTGRESQL_ADDON_USER=  (injected by CC)
# POSTGRESQL_ADDON_PASSWORD= (injected by CC)

# ── Redis (auto-injected by Clever Cloud Redis addon) ────────────────────
# REDIS_HOST=             (injected by CC)
# REDIS_PORT=             (injected by CC)
# REDIS_PASSWORD=         (injected by CC)

# ── Security ─────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── LLM Providers ────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_MODEL_ID=gpt-4o
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096

# ── File Storage ─────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
